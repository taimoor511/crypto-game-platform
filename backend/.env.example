# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/crypto-game

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# BSC Testnet Configuration
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545/
BSC_CHAIN_ID=97

# USDT Contract (BSC Testnet)
USDT_CONTRACT_ADDRESS=0x337610d27c682E347C9cD60BD4b3b107C9d34dDd

# Platform Wallets (CHANGE THESE - Generate new wallets for production)
DEPOSIT_WALLET_PRIVATE_KEY=your_deposit_wallet_private_key_here
POOL_WALLET_PRIVATE_KEY=your_pool_wallet_private_key_here
REWARD_WALLET_PRIVATE_KEY=your_reward_wallet_private_key_here

# Email Configuration (for withdrawal confirmations)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Withdrawal Limits
MAX_WITHDRAWAL_AMOUNT=10
MAX_DAILY_WITHDRAWAL=50
WITHDRAWAL_COOLDOWN_HOURS=24

# CORS
CORS_ORIGIN=http://localhost:3000
